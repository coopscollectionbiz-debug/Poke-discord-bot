# =====================================================
# Discord — required
# =====================================================
# From the Discord Developer Portal (see README §2).
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id

# Test server + private backup channel (see README §4).
GUILD_ID=your_test_server_id
STORAGE_CHANNEL_ID=your_private_backup_channel_id

# =====================================================
# Runtime
# =====================================================
NODE_ENV=development
PORT=3000
# Set true on first run so slash commands register to GUILD_ID.
# Flip to false afterwards to avoid re-registering on every boot.
REGISTER_COMMANDS=true

# =====================================================
# Hosting
# =====================================================
# Base URL the /dashboard Discord embed links to.
#   • Render (prod): auto-injected, leave blank.
#   • Any other host (Fly.io, Railway, self-hosted, etc.):
#     set this to your public base URL.
#   • Local dev: set it to your local Express server (must
#     match PORT above), e.g. http://localhost:3000
# Without a correct value, /dashboard links point at the wrong
# host and tokens won't validate against your running process.
RENDER_EXTERNAL_URL=

# Persistent volume path for trainerData.json on Fly.io / Render
# persistent disks. Defaults to ".".
TRAINERDATA_DIR=
